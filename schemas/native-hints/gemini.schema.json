{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://landi.io/schemas/gemini.schema.json",
  "type": "object",
  "properties": {
    "provider": { "const": "gemini" },
    "useSystemInstruction": { "type": "boolean" },
    "thinkingBudget": { "type": "number", "minimum": 0 },
    "safetySettings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "threshold": { "type": "string" }
        },
        "required": ["category", "threshold"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "required": ["provider"]
}
